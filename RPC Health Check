#!/bin/bash
clear  # Clear the terminal at the very start

# --- Dependencies check & install ---
declare -A TOOLS=( [curl]="curl" [jq]="jq" [bc]="bc" [gawk]="gawk" )

# Determine OS package manager and install commands
if command -v dnf &> /dev/null; then
    INSTALL_CMD="dnf install -qy"
elif command -v apt-get &> /dev/null; then
    INSTALL_CMD="apt-get install -qqy"
elif command -v pacman &> /dev/null; then
    INSTALL_CMD="pacman -S --noconfirm --needed"
else
    echo "Unsupported package manager. Please install dependencies manually:"
    printf '%s\n' "${TOOLS[@]}"
    exit 1
fi

# Check and install dependencies only if missing
for tool in "${!TOOLS[@]}"; do
    if ! command -v "$tool" &> /dev/null; then
        if ! $INSTALL_CMD "${TOOLS[$tool]}" &> /dev/null; then
            :
        fi
    fi
done

# --- Tools status ---
FOUND=0; MISSING=()
for tool in "${!TOOLS[@]}"; do
    if command -v "$tool" &> /dev/null; then
        ((FOUND++))
    else
        MISSING+=("${TOOLS[$tool]}")
    fi
done

# --- Colors ---
GREEN='\e[0;32m'
RED='\e[0;31m'
YELLOW='\e[0;33m'
BLUE='\e[0;34m'
CYAN='\e[0;36m'
RESET='\e[0m'

if (( FOUND == 4 )); then
    TOOL_STATUS="${GREEN}Found (4/4) âś“${RESET}"
elif (( ${#MISSING[@]} > 0 )); then
    TOOL_STATUS="${RED}Not Found (${FOUND}/4) âś— (${MISSING[*]})${RESET}"
else
    TOOL_STATUS="${YELLOW}Error (unexpected tool count)${RESET}"
fi

# --- Header and separators ---
SEP_WIDTH=50
sep_equals() { printf '=%.0s' $(seq 1 $SEP_WIDTH); echo; }
sep_dashes() { printf -- '-%.0s' $(seq 1 $SEP_WIDTH); echo; }
center_text() {
    local text="$1"
    local padding=$(( (SEP_WIDTH - ${#text}) / 2 ))
    printf "%*s%s%*s\n" $padding "" "$text" $padding ""
}

sep_equals
center_text "ETHEREUM NODE HEALTH CHECKER"
sep_equals
echo -ne "Tools : $TOOL_STATUS"     # <- NO extra newline before "â—Ź RPC Endpoints"

# --- RPC input ---
echo -e "\nâ—Ź RPC Endpoints"
read -rp "Enter Sepolia RPC URL: " SEPOLIA_RPC
echo -ne "\033[1A\033[K"; echo -e "Sepolia RPC Set ${GREEN}âś“${RESET}"
read -rp "Enter Beacon RPC URL : " BEACON_RPC
echo -ne "\033[1A\033[K"; echo -e "Beacon RPC Set ${GREEN}âś“${RESET}"

# --- Sepolia check ---
echo -e "\nâ—Ź Sepolia RPC Check"
RESPONSE=$(curl -s -w "\n%{http_code}" -X POST "$SEPOLIA_RPC" \
 -H "Content-Type: application/json" \
 --data '{"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}')
HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
BODY=$(echo "$RESPONSE" | sed '$d')
if [[ "$HTTP_CODE" == "200" ]]; then
    BLOCKNUM=$(echo "$BODY" | jq -r '.result' 2>/dev/null)
    if [[ "$BLOCKNUM" != "null" && "$BLOCKNUM" != "" ]]; then
        DEC_BLOCKNUM=$((16#${BLOCKNUM:2}))
        echo -e "${GREEN}âś“ Healthy${RESET} (Block: ${DEC_BLOCKNUM})"
        SEPOLIA_OK=1
    else
        echo -e "${RED}âś— Unhealthy${RESET}"; SEPOLIA_OK=0
    fi
else
    echo -e "${RED}âś— Unreachable (HTTP $HTTP_CODE)${RESET}"; SEPOLIA_OK=0
fi

# --- Beacon check ---
echo -e "\nâ—Ź Beacon Node Check"
BEACON_RESPONSE=$(curl -s -w "\n%{http_code}" --max-time 5 "$BEACON_RPC/eth/v1/node/version")
BEACON_HTTP_CODE=$(echo "$BEACON_RESPONSE" | tail -n1)
BEACON_BODY=$(echo "$BEACON_RESPONSE" | sed '$d')
if [[ "$BEACON_HTTP_CODE" == "200" ]]; then
    VER=$(echo "$BEACON_BODY" | jq -r '.data.version' 2>/dev/null)
    if [[ "$VER" && "$VER" != "null" ]]; then
        echo -e "${GREEN}âś“ Reachable${RESET} (Version: ${VER})"
        BEACON_OK=1
    else
        echo -e "${YELLOW}âš  Invalid JSON response format${RESET}"; BEACON_OK=0
    fi
else
    echo -e "${RED}âś— Unreachable (HTTP $BEACON_HTTP_CODE)${RESET}"; BEACON_OK=0
fi

# --- Head slot ---
HEAD=""
if [[ $BEACON_OK -eq 1 ]]; then
    HEAD_RESPONSE=$(curl -s -w "\n%{http_code}" --max-time 5 "$BEACON_RPC/eth/v1/beacon/headers/head")
    HEAD_HTTP_CODE=$(echo "$HEAD_RESPONSE" | tail -n1)
    HEAD_BODY=$(echo "$HEAD_RESPONSE" | sed '$d')
    if [[ "$HEAD_HTTP_CODE" == "200" ]]; then
        HEAD=$(echo "$HEAD_BODY" | jq -r '.data.header.message.slot' 2>/dev/null)
        [[ ! "$HEAD" =~ ^[0-9]+$ ]] && HEAD=""
    fi
fi

# --- Blob sidecars check ---
if [[ -n "$HEAD" ]]; then
    echo -e "\nâ—Ź Blob Sidecars Check (Last 10 Slots)"
    TOTAL=10; SLOTS_WITH_BLOBS=0; TOTAL_BLOBS=0; BLOB_FETCH_ERRORS=0
    for ((i=0; i<TOTAL; i++)); do
        SLOT=$((HEAD-i))
        BLOB_RESPONSE=$(curl -s -w "\n%{http_code}" --max-time 10 "$BEACON_RPC/eth/v1/beacon/blob_sidecars/$SLOT")
        BLOB_HTTP_CODE=$(echo "$BLOB_RESPONSE" | tail -n1)
        BLOB_BODY=$(echo "$BLOB_RESPONSE" | sed '$d')
        N=$(echo "$BLOB_BODY" | jq -r '.data | length' 2>/dev/null)
        if [[ "$BLOB_HTTP_CODE" == "200" && "$N" =~ ^[1-9][0-9]*$ ]]; then
            echo -e "${GREEN}âś“ Slot $SLOT: Fetch success, $N blob(s)${RESET}"
            ((SLOTS_WITH_BLOBS++)); ((TOTAL_BLOBS+=N))
        else
            echo -e "${RED}âś— Slot $SLOT: No blobs or fetch failed${RESET}"
            ((BLOB_FETCH_ERRORS++))
        fi
    done
    SUCCESS_RATE=$((SLOTS_WITH_BLOBS*100/TOTAL))
    if (( SUCCESS_RATE < 40 )); then STATUS="${RED}CRITICAL${RESET}"
    elif (( SUCCESS_RATE < 70 )); then STATUS="${YELLOW}WARNING${RESET}"
    else STATUS="${GREEN}HEALTHY${RESET}"; fi

    # --- Burst / Rate limit test ---
    echo -e "\nâ—Ź Rate Limiting Check (100-req burst)"
    TARGET_ENDPOINT="$BEACON_RPC/eth/v1/beacon/blob_sidecars/head"
    REQS=100
    START_MS=$(date +%s%3N)
    HTTP_CODES=$(seq 1 $REQS | xargs -P$REQS -I{} \
        curl -s -o /dev/null -w "%{http_code}\n" --max-time 5 "$TARGET_ENDPOINT")
    END_MS=$(date +%s%3N)
    ELAPSED_MS=$((END_MS - START_MS))
    RPS=$(gawk "BEGIN {print $REQS/($ELAPSED_MS/1000)}")

    # --- RPS sanitization ---
    [[ -z "$RPS" ]] && RPS=0
    RPS=$(echo "$RPS" | tr ',' '.')  # Ensure decimal dot, not comma
    if ! [[ "$RPS" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
        RPS=0
    fi

    if echo "$HTTP_CODES" | grep -q "429"; then
        RL_COUNT=$(echo "$HTTP_CODES" | grep -c "429")
        echo -e "${RED}âś— Rate limit detected ($RL_COUNT/$REQS HTTP 429)${RESET}"
    else
        echo -e "${GREEN}âś“ No rate limiting detected${RESET}"
    fi
    echo "Completed in ${ELAPSED_MS} ms (~${RPS} req/sec)"
fi

# --- Assign Tier ---
if (( $(echo "$RPS >= 200" | bc -l) )); then
    TIER_STRING="Tier S - Kage"
elif (( $(echo "$RPS >= 100" | bc -l) )); then
    TIER_STRING="Tier A - Jonin"
elif (( $(echo "$RPS >= 50" | bc -l) )); then
    TIER_STRING="Tier B - Chunin"
else
    TIER_STRING="Tier C - Genin"
fi

# --- Verdict Logic ---
if [[ ${SEPOLIA_OK:-0} -ne 1 || ${BEACON_OK:-0} -ne 1 ]]; then
    VERDICT="${RED}Not Suitable for Node${RESET}"
else
    if (( SUCCESS_RATE >= 70 )); then
        case "$TIER_STRING" in
            "Tier S - Kage") VERDICT="${GREEN}Enterprise â€“ Kage Node${RESET}" ;;
            "Tier A - Jonin") VERDICT="${GREEN}Production â€“ Jonin Node${RESET}" ;;
            "Tier B - Chunin") VERDICT="${CYAN}Stable â€“ Chunin Node${RESET}" ;;
            "Tier C - Genin") VERDICT="${CYAN}Stable â€“ Genin Node${RESET}" ;;
        esac
    elif (( SUCCESS_RATE >= 40 )); then
        case "$TIER_STRING" in
            "Tier S - Kage") VERDICT="${GREEN}Production â€“ Kage Node${RESET}" ;;
            "Tier A - Jonin") VERDICT="${CYAN}Stable â€“ Jonin Node${RESET}" ;;
            "Tier B - Chunin") VERDICT="${YELLOW}Unstable â€“ Chunin Node${RESET}" ;;
            "Tier C - Genin") VERDICT="${YELLOW}Unstable â€“ Genin Node${RESET}" ;;
        esac
    else
        VERDICT="${RED}Not Suitable${RESET}"
    fi
fi

# --- Summary ---
sep_equals
center_text "Summary"
sep_equals
echo -e "Sepolia RPC   : $( [[ ${SEPOLIA_OK:-0} -eq 1 ]] && echo -e "${GREEN}OK${RESET}" || echo -e "${RED}FAIL${RESET}" )"
echo -e "Beacon RPC    : $( [[ ${BEACON_OK:-0} -eq 1 ]] && echo -e "${GREEN}OK${RESET}" || echo -e "${RED}FAIL${RESET}" )"
[[ -n "$HEAD" ]] && echo -e "Blob Health   : $STATUS"
[[ -n "$HEAD" ]] && echo -e "Rate Tier     : ${TIER_STRING}"
[[ -n "$HEAD" ]] && echo -e "Blob Success  : $SLOTS_WITH_BLOBS/$TOTAL slots (${SUCCESS_RATE}%)"
[[ -n "$HEAD" ]] && echo -e "Total Blobs   : $TOTAL_BLOBS"
[[ -n "$HEAD" ]] && echo -e "Blob Errors   : $BLOB_FETCH_ERRORS/$TOTAL"
sep_dashes
echo -e "Rate Tiers:"
echo -e "S â‰Ą 200       (Kage)"
echo -e "A = 100-199   (Jonin)"
echo -e "B = 50-99     (Chunin)"
echo -e "C < 50        (Genin)"
sep_equals
echo -e "Verdict : $VERDICT"
sep_equals
